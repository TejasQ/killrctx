# =================================================================
# Copy this file to `.env` and fill in the secret-marked fields.
# Lines you DO NOT need to edit are kept as-is. The values that need
# you to do something are marked  <<< SET ME >>>.
# =================================================================

# =================================================================
# Next.js app -> OpenRAG backend
# =================================================================
OPENRAG_URL=http://localhost:8000
# /router/upload_ingest goes through the backend's non-Langflow ingestion
# path (Docling -> embed -> OpenSearch). The /langflow/upload_ingest path
# also exists but depends on Langflow minting an API key, which is fragile
# on first boot.
OPENRAG_INGEST_PATH=/router/upload_ingest

# =================================================================
# ElevenLabs
# ElevenLabs has been gradually reclassifying its "default" preset voices
# into the paid Voice Library — even ones that used to be free (Aria,
# Brian, George, Rachel...) now return 402 paid_plan_required when called
# via the API on a free-tier key. The two IDs below are the only ones
# verified to still work on a brand-new free account as of mid-2026:
#   bIHbv24MWmeRgasZH58o   (Will)
#   bVMeCyTHy58xNoL34h3p   (Hope)
# If those stop working too, log into https://elevenlabs.io/app/voice-library
# and click "Add to my voices" on a voice you like — your personal voice
# IDs are always API-accessible regardless of plan.
# =================================================================
ELEVENLABS_API_KEY=                           # <<< SET ME — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_HOST_VOICE_ID=bIHbv24MWmeRgasZH58o
ELEVENLABS_GUEST_VOICE_ID=bVMeCyTHy58xNoL34h3p
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# =================================================================
# OpenRAG stack (docker-compose)
# =================================================================
OPENRAG_VERSION=latest

# Throwaway dev secrets — pre-generated so you can `cp .env.example .env`
# and go. THESE ARE PUBLIC; regenerate before any non-local deployment.
#
# OpenSearch password must include upper/lower/digit/special chars or it
# refuses to start. Even though we run with the security plugin disabled
# (see docker-compose.yml), the upstream image still validates the value.
#   $ openssl rand -hex 16; echo "Aa1!"  # then concatenate
OPENSEARCH_PASSWORD=0e65a5f9147c768099fc4443a1cc0986Aa1!
OPENSEARCH_USERNAME=admin
OPENSEARCH_INDEX_NAME=documents

# Required secrets — generated with `openssl rand -hex 32` for everything
# EXCEPT LANGFLOW_SECRET_KEY, which Langflow uses as a Fernet key (32
# url-safe base64-encoded bytes, 44 chars ending in `=`):
#   $ python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
SESSION_SECRET=6b6978c5cd2e02b5519f1a63693a016ff8cfd41f84b3641ebbf8bd42e43989fb
JWT_SIGNING_KEY=d593eef22b2e9bfd51f19409000e0075872135a8f1368ba2e01e94364af8ceb4
OPENRAG_ENCRYPTION_KEY=963e0ec6e92418bd2af1cf1467010374b6cb021be141d6a07f81a9c8ae1c3c3c
LANGFLOW_SECRET_KEY=U21UBvvRAms5_vTfRKPHVeZGev_26OhYxPqMEG5P3v8=
LANGFLOW_KEY=5ebb0097a68b0d18d8956f8616a61417751aac3f32a363b04675aafc4649a42f

# Langflow admin
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_NEW_USER_IS_ACTIVE=true
LANGFLOW_ENABLE_SUPERUSER_CLI=true
LANGFLOW_PUBLIC_URL=http://localhost:7860
LANGFLOW_PORT=7860

# Flow IDs — leave blank for first boot. OpenRAG seeds defaults if
# INGEST_SAMPLE_DATA=true (we keep it false to skip the slow seed step).
LANGFLOW_CHAT_FLOW_ID=
LANGFLOW_INGEST_FLOW_ID=
LANGFLOW_URL_INGEST_FLOW_ID=
DISABLE_INGEST_WITH_LANGFLOW=true
INGEST_SAMPLE_DATA=false

# OpenRAG's own UI (separate from our Next.js app — runs on this port)
FRONTEND_PORT=3000

# LLM provider keys — only OPENAI_API_KEY is required for the default
# stack. Anthropic / WatsonX / Ollama support is included by upstream
# OpenRAG but not exercised by this app.
OPENAI_API_KEY=                               # <<< SET ME — https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=
WATSONX_API_KEY=
WATSONX_ENDPOINT=
WATSONX_PROJECT_ID=
OLLAMA_ENDPOINT=
SELECTED_EMBEDDING_MODEL=text-embedding-3-small

# Docling — runs as a sibling container in docker-compose. Override only
# if you're running docling-serve elsewhere (e.g. on the host via
# `uvx docling-serve run`, then http://host.docker.internal:5001).
DOCLING_SERVE_URL=http://docling:5001
